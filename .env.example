# Copy to .env (do not commit). Values override defaults in liteinsurance.php.

# Required for web-based cron calls (recommended). Use a long random string.
CRON_TOKEN="change-me-please-32chars-min"

# Optional: move SQLite DB outside webroot if your hosting allows it.
# DB_PATH="/home/USER/liteinsurance/liteinsurance.db"

# Optional: move uploads outside webroot if your hosting allows it.
# UPLOAD_DIR="/home/USER/liteinsurance/liteinsurance_uploads"
